{
  "name": "srf-spiritual-diary",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "npm run test:lib && npm run test:components",
    "test:lib": "node --experimental-strip-types --test src/lib/*.test.ts",
    "test:components": "vitest run",
    "lint": "tsc --noEmit",
    "verify": "tsc --noEmit && npm test && vite build",
    "pipeline:daily": "node scripts/daily-pipeline.mjs",
    "seed:supabase": "node scripts/seed-diary-entries.mjs",
    "patch-missing-dates": "node scripts/merge-diary-json.mjs --patch data/missing-dates-patch.json"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@vercel/node": "^5.3.24",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@headlessui/react": "^2.2.9",
    "@supabase/supabase-js": "^2.58.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.22",
    "idb": "^8.0.3",
    "lucide-react": "^0.544.0",
    "openai": "^6.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite-plugin-react": "^4.0.1"
  }
}
