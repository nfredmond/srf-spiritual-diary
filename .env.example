GEMINI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Vite-exposed copies so the SPA can read directly from Supabase.
# Keep these equal to SUPABASE_URL / SUPABASE_ANON_KEY.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# auto (default) = Supabase first, JSON fallback; supabase = Supabase only; json = JSON only.
VITE_SRF_DATA_SOURCE=auto
SRF_DRIVE_ROOT_FOLDER_ID=
SRF_EMAIL_TO=
SRF_TELEGRAM_TARGET=
SRF_SLACK_TARGET=
SRF_DISCORD_TARGET=
SRF_OPENCLAW_CHANNEL_TELEGRAM=telegram
SRF_OPENCLAW_CHANNEL_SLACK=slack
SRF_OPENCLAW_CHANNEL_DISCORD=discord
SRF_GENERATION_MODEL=gemini-2.5-flash-image
SRF_TEXT_MODEL=gemini-2.5-flash
SRF_ALLOW_OM_SYMBOL=true
# Phase 2: image provider selection. "gemini" (default, cloud) or "comfyui" (local SDXL).
SRF_IMAGE_PROVIDER=gemini
# Supabase Storage bucket for ComfyUI output (must exist, public read).
SRF_IMAGE_BUCKET=daily-renders
# ComfyUI backend (local only — Vercel cannot reach this).
SRF_COMFY_HOST=http://127.0.0.1:8188
SRF_COMFY_CHECKPOINT=RealVisXL_V5.0_fp16.safetensors
SRF_COMFY_LORA=from_checkpoints/SDXL/Hyper-SDXL-8steps-CFG-lora.safetensors
SRF_COMFY_STEPS=8
SRF_COMFY_CFG=5.0
SRF_COMFY_SAMPLER=dpmpp_sde
SRF_COMFY_SCHEDULER=karras
SRF_COMFY_SIZE=1024x1024
SRF_COMFY_TIMEOUT_MS=180000
SRF_FROM_EMAIL=
SRF_APP_URL=
CRON_SECRET=
SRF_RUN_DAILY_TOKEN=
